# =============================================================================
# CALL CENTER AI WORKFLOW - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit the actual .env file to version control

# =============================================================================
# N8N Configuration
# =============================================================================
N8N_HOST=0.0.0.0
N8N_PORT=5678
N8N_PROTOCOL=https
N8N_BASE_URL=https://n8n.yourdomain.com
N8N_WEBHOOK_BASE=https://n8n.yourdomain.com

# N8N Security
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=your_secure_password_here

# N8N Database (PostgreSQL recommended for production)
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=localhost
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=n8n_user
DB_POSTGRESDB_PASSWORD=your_db_password_here

# =============================================================================
# Aircall Configuration
# =============================================================================
AIRCALL_API_ID=your_aircall_api_id
AIRCALL_API_TOKEN=your_aircall_api_token
AIRCALL_WEBHOOK_SECRET=your_webhook_signing_secret

# =============================================================================
# AWS Configuration
# =============================================================================
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-east-1

# S3 Buckets
S3_RAW_AUDIO_BUCKET=callcenter-raw-audio-prod
S3_PROCESSED_BUCKET=callcenter-processed-prod

# =============================================================================
# Azure OpenAI Configuration
# =============================================================================
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your_azure_openai_key_here
AZURE_OPENAI_API_VERSION=2024-02-01

# Model Deployments (names you gave when deploying models)
WHISPER_DEPLOYMENT=whisper-1
GPT4_DEPLOYMENT=gpt-4-turbo
EMBEDDING_DEPLOYMENT=text-embedding-ada-002

# =============================================================================
# HubSpot Configuration
# =============================================================================
HUBSPOT_ACCESS_TOKEN=pat-na1-xxxxx
# Or use OAuth
HUBSPOT_CLIENT_ID=your_client_id
HUBSPOT_CLIENT_SECRET=your_client_secret
HUBSPOT_REFRESH_TOKEN=your_refresh_token

# =============================================================================
# Avoma Configuration
# =============================================================================
AVOMA_API_KEY=your_avoma_api_key
AVOMA_API_ENDPOINT=https://api.avoma.com

# =============================================================================
# Pinecone Configuration
# =============================================================================
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX=call-transcripts
PINECONE_PROJECT=your_project_id

# =============================================================================
# Slack Configuration (for notifications)
# =============================================================================
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_CHANNEL_CALLS=#call-center-notifications
SLACK_CHANNEL_ALERTS=#call-center-alerts
SLACK_CHANNEL_ONCALL=#oncall-critical

# =============================================================================
# Optional: Monitoring & Observability
# =============================================================================
# Datadog (optional)
DD_API_KEY=your_datadog_api_key
DD_SITE=datadoghq.com

# Sentry (optional)
SENTRY_DSN=https://xxx@sentry.io/xxx

# =============================================================================
# Feature Flags
# =============================================================================
ENABLE_AVOMA_SYNC=true
ENABLE_PINECONE_SYNC=true
ENABLE_SLACK_NOTIFICATIONS=true
ENABLE_ERROR_RETRIES=true
MAX_RETRY_ATTEMPTS=3
