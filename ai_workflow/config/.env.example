# =============================================================================
# CALL CENTER AI WORKFLOW - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit the actual .env file to version control

# =============================================================================
# N8N Configuration
# =============================================================================
N8N_CLOUD_URL=https://your-instance.app.n8n.cloud
# Note: n8n Cloud free plan does NOT support environment variables.
# All values must be hardcoded in workflow JSONs.

# =============================================================================
# Aircall Configuration
# =============================================================================
AIRCALL_API_ID=your_aircall_api_id
AIRCALL_API_TOKEN=your_aircall_api_token
AIRCALL_WEBHOOK_URL=https://your-instance.app.n8n.cloud/webhook/aircall-webhook
AIRCALL_WEBHOOK_TOKEN=your_webhook_token

# =============================================================================
# AWS Configuration
# =============================================================================
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-east-1

# S3 Buckets
S3_RAW_AUDIO_BUCKET=callcenter-raw-audio-prod-1-yourname
S3_PROCESSED_BUCKET=callcenter-processed-transcripts-prod-1-yourname

# =============================================================================
# Azure OpenAI - Whisper (Transcription)
# =============================================================================
# Whisper may be on a separate Azure resource from GPT-4/Embeddings
AZURE_WHISPER_ENDPOINT=https://your-whisper-resource.cognitiveservices.azure.com
AZURE_WHISPER_API_KEY=your_whisper_api_key
AZURE_WHISPER_DEPLOYMENT=whisper-1
AZURE_WHISPER_API_VERSION=2024-06-01

# =============================================================================
# Azure OpenAI - GPT-4 & Embeddings
# =============================================================================
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your_azure_openai_key
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# GPT-4 deployment
GPT4_DEPLOYMENT=your-gpt-4o-mini-deployment

# Embedding deployment (text-embedding-3-small, 1536 dimensions)
EMBEDDING_DEPLOYMENT=your-text-embedding-3-small-deployment

# =============================================================================
# HubSpot Configuration
# =============================================================================
# Using Private App token (not OAuth)
HUBSPOT_ACCESS_TOKEN=pat-na1-xxxxx
HUBSPOT_HUB_ID=your_hub_id

# =============================================================================
# Avoma Configuration
# =============================================================================
# Note: Avoma auto-syncs Aircall calls via native integration.
# The /v1/meetings/ API is GET-only (read). No API push needed.
AVOMA_API_KEY=your_avoma_api_key

# =============================================================================
# Pinecone Configuration
# =============================================================================
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX_HOST=https://your-index.svc.pinecone.io
PINECONE_INDEX_NAME=call-transcripts
PINECONE_NAMESPACE=call_transcripts
# Index: Dense, 1536 dimensions, cosine metric
# Metadata must be flat values (string, number, boolean, list of strings)

# =============================================================================
# Telegram Configuration (Notifications & Alerts)
# =============================================================================
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# =============================================================================
# Error Handler Configuration
# =============================================================================
MAX_RETRY_ATTEMPTS=3
DLQ_S3_PATH=errors/dlq/
