    {
      "parameters": {
        "jsCode": "const inputData = $input.first().json.body || $input.first().json;\n\nconst startDate = inputData.metadata?.started_at || new Date().toISOString();\nconst endDate = inputData.metadata?.ended_at || new Date().toISOString();\n\nconst avomaPayload = {\n  external_id: String(inputData.call_id),\n  title: 'Call with ' + (inputData.metadata?.caller_name || 'Customer'),\n  from_date: startDate,\n  to_date: endDate,\n  duration_minutes: Math.ceil((inputData.metadata?.duration_seconds || 0) / 60),\n  participants: [\n    {\n      name: inputData.metadata?.caller_name || 'Customer',\n      role: 'external'\n    },\n    {\n      name: inputData.metadata?.agent_name || 'Agent',\n      email: inputData.metadata?.agent_email || null,\n      role: 'internal'\n    }\n  ],\n  summary: inputData.analysis?.summary || '',\n  topics: inputData.analysis?.topics || [],\n  action_items: (inputData.analysis?.action_items || []).map(function(item) {\n    return { description: item, status: 'pending' };\n  }),\n  source: 'call_center_ai',\n  call_direction: inputData.metadata?.direction || 'inbound'\n};\n\nreturn [{ json: avomaPayload }];\n"
      },
      "id": "0a5477d5-872f-4c17-ae61-9374ceb6f54c",
