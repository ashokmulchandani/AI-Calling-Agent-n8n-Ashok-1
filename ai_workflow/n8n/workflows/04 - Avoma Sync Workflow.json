        "jsCode": "const avomaResponse = $('Create Avoma Meeting').first().json;\nconst inputData = $('Avoma Sync Trigger').first().json.body || $('Avoma Sync Trigger').first().json;\n\nreturn [{\n  json: {\n    meeting_id: avomaResponse.id,\n    notes: [\n      {\n        type: 'summary',\n        title: 'AI Summary',\n        content: inputData.analysis?.summary || 'No summary available'\n      },\n      {\n        type: 'key_topics',\n        title: 'Topics Discussed',\n        content: (inputData.analysis?.topics || []).join(', ') || 'None'\n      },\n      {\n        type: 'entities',\n        title: 'Entities Mentioned',\n        content: (inputData.analysis?.entities || []).join(', ') || 'None'\n      }\n    ]\n  }\n}];\n"
