    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst binaryKey = Object.keys(items[0].binary)[0];\nconst binaryBuffer = await this.helpers.getBinaryDataBuffer(0, binaryKey);\nlet jsonString = binaryBuffer.toString('utf-8').trim();\nif (jsonString.startsWith('=')) {\n  jsonString = jsonString.substring(1).trim();\n}\nconst analysisData = JSON.parse(jsonString);\n\nreturn [{ json: analysisData }];\n"
      },
