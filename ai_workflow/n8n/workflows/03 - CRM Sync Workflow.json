    {
      "parameters": {
        "jsCode": "const contacts = $('Search HubSpot Contact').first().json;\nconst analysisData = $('Parse Analysis').first().json;\n\nlet contactId;\nif (Array.isArray($('Search HubSpot Contact').all()) && $('Search HubSpot Contact').all().length > 0) {\n  contactId = $('Search HubSpot Contact').first().json.id;\n} else {\n  contactId = 'unknown';\n}\n\nreturn [{\n  json: {\n    contact_id: contactId,\n    analysis: analysisData\n  }\n}];\n"
      },
      "id": "0a7589c6-84a7-4793-8b82-65e89c5483f8",
      "name": "Get Contact ID",
      "type": "n8n-nodes-base.code",
