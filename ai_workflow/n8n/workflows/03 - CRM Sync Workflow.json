      "position": [
        -240,
        688
      ]
    },
    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst analysis = data.analysis;\n\nconst noteBody = `\nCall Summary: ${analysis.analysis?.summary || 'N/A'}\n\nCustomer Intent: ${analysis.analysis?.customer_intent || 'N/A'}\n\nResolution: ${analysis.analysis?.resolution_status || 'unknown'}\n\nSentiment: ${analysis.analysis?.sentiment || 'neutral'}\n\nTopics: ${(analysis.analysis?.topics || []).join(', ') || 'None'}\n\nAction Items: ${(analysis.analysis?.action_items || []).join(', ') || 'None'}\n\nCall Details:\n- Duration: ${Math.floor((analysis.transcript?.duration || 0) / 60)}m\n- Agent: ${analysis.metadata?.agent_name || 'Unknown'}\n- Call ID: ${analysis.call_id}\n`;\n\nreturn [{\n  json: {\n    contact_id: data.contact_id,\n    note_body: noteBody,\n    call_id: analysis.call_id,\n    timestamp: analysis.metadata?.ended_at || new Date().toISOString()\n  }\n}];\n"
      },
