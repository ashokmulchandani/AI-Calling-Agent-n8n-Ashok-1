      "id": "daa5a36a-db65-4a93-b6f2-4dad481f7250",
      "name": "Azure Whisper Transcription1",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        2800,
        432
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "SQmv9So7FGkcmUbu",
          "name": "Header Auth account 6"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const whisperResponse = $input.first().json;\nconst inputData = $('Extract Body').first().json;\n\n\n\nconst transcript = {\n  call_id: inputData.call_id,\n  full_text: whisperResponse.text,\n  language: whisperResponse.language,\n  duration: whisperResponse.duration,\n  segments: (whisperResponse.segments || []).map(seg => ({\n    id: seg.id,\n    start: seg.start,\n    end: seg.end,\n    text: seg.text.trim(),\n    confidence: seg.confidence || null\n  })),\n  word_count: whisperResponse.text.split(/\\s+/).length,\n  transcribed_at: new Date().toISOString()\n};\n\nreturn [{ json: transcript }];\n"
      },
      "id": "0c29c25c-adeb-4783-a370-ed3df530a8cb",
      "name": "Process Transcript1",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3008,
        432
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://testashok1.openai.azure.com/openai/deployments/testashok1-gpt-4o-mini/chat/completions?api-version=2025-01-01-preview",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are an expert call center analyst. Analyze the following call transcript and extract structured information. Be precise and factual.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Analyze this call transcript and provide:\\n\\n1. **Call Summary** (2-3 sentences)\\n2. **Customer Intent** (what the customer wanted)\\n3. **Resolution Status** (resolved/unresolved/escalated)\\n4. **Key Topics** (list of main topics discussed)\\n5. **Customer Sentiment** (positive/neutral/negative with confidence 0-100)\\n6. **Action Items** (any follow-ups needed)\\n7. **Entities Mentioned** (products, services, account numbers, etc.)\\n\\nTranscript:\\n{{ $json.full_text }}\\n\\nRespond in JSON format with these exact keys: summary, customer_intent, resolution_status, topics, sentiment, action_items, entities\"\n    }\n  ],\n  \"temperature\": 0.3,\n  \"max_tokens\": 2000,\n  \"response_format\": { \"type\": \"json_object\" }\n}",
        "options": {}
      },
      "id": "d2e3f338-66aa-4a78-840c-e7cb71203101",
      "name": "GPT-4 Call Analysis1",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        3200,
        432
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "FSRFj6dnf9FUrPrj",
          "name": "Header Auth account 7"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const gptResponse = $input.first().json;\nconst transcript = $('Process Transcript1').first().json;\nconst inputData = $('Extract Body').first().json;\n\n\nlet analysis;\ntry {\n  const content = gptResponse.choices[0].message.content;\n  analysis = JSON.parse(content);\n} catch (e) {\n  analysis = {\n    summary: 'Analysis parsing failed',\n    customer_intent: 'Unknown',\n    resolution_status: 'unknown',\n    topics: [],\n    sentiment: { label: 'neutral', confidence: 0 },\n    action_items: [],\n    entities: []\n  };\n}\n\nconst processedCall = {\n  call_id: transcript.call_id,\n  transcript: {\n    full_text: transcript.full_text,\n    segments: transcript.segments,\n    word_count: transcript.word_count,\n    duration: transcript.duration,\n    language: transcript.language\n  },\n  analysis: {\n    summary: analysis.summary,\n    customer_intent: analysis.customer_intent,\n    resolution_status: analysis.resolution_status,\n    topics: Array.isArray(analysis.topics) ? analysis.topics : [],\n    sentiment: analysis.sentiment,\n    action_items: Array.isArray(analysis.action_items) ? analysis.action_items : [],\n    entities: Array.isArray(analysis.entities) ? analysis.entities : []\n  },\n  metadata: inputData.metadata || {},\n  processing: {\n    transcribed_at: transcript.transcribed_at,\n    analyzed_at: new Date().toISOString(),\n    model_used: 'gpt-4o',\n    whisper_model: 'whisper-1',\n    workflow_version: '1.0.0'\n  }\n};\n\nreturn [{ json: processedCall }];\n"
      },
      "id": "2e40c460-84e6-4c47-b3ec-310b21053e7f",
      "name": "Combine Results1",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3408,
        432
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://testashok1.openai.azure.com/openai/deployments/testashok1-noble-oak-text-embedding-3-small/embeddings?api-version=2023-05-15",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"input\": \"{{ $json.transcript.full_text.substring(0, 8000) }}\",\n  \"model\": \"text-embedding-ada-002\"\n}",
        "options": {}
      },
      "id": "d42a0266-6926-444e-8afb-6b0e6fc8da15",
      "name": "Generate Embedding1",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        3600,
        432
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "Ah8jicAqlKm5yct7",
          "name": "Header Auth account 8"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const processedCall = $('Combine Results1').first().json;\nconst embeddingResponse = $input.first().json;\n\nprocessedCall.embedding = {\n  vector: embeddingResponse.data[0].embedding,\n  model: 'text-embedding-3-small',\n  dimensions: embeddingResponse.data[0].embedding.length,\n  generated_at: new Date().toISOString()\n};\n\nreturn [{ json: processedCall }];\n"
      },
      "id": "1bcceff4-e954-44f9-bd0f-711bf597eff6",
      "name": "Add Embedding1",
