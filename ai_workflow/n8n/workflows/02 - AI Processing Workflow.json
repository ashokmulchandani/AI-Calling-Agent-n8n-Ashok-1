        "url": "https://ashok-mnuduagy-eastus2.cognitiveservices.azure.com/openai/deployments/whisper-1/audio/transcriptions?api-version=2024-06-01",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "contentType": "multipart-form-data",
        "bodyParameters": {
          "parameters": [
            {
