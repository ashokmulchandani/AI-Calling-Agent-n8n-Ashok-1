        "jsCode": "const data = $('Add Embedding1').first().json;\nconst response = await this.helpers.httpRequest({\n  method: 'POST',\n  url: 'https://aiamfspr.app.n8n.cloud/webhook/vector-sync',\n  body: data,\n  headers: { 'Content-Type': 'application/json' }\n});\nreturn [{ json: { pinecone_trigger: 'sent', call_id: data.call_id } }];\n"
      },
