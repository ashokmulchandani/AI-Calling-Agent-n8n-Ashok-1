            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
  "tags": [
    {
      "name": "call-center",
      "id": "tag-call-center"
    },
    {
      "name": "crm-sync",
      "id": "tag-crm-sync"
    }
  ]
}
