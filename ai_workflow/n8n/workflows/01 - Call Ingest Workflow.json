      "id": "ff63166d-fd70-477f-99e6-cb5f55544d7e",
      "name": "Filter Call Ended",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        5312,
        2192
      ]
    },
    {
      "parameters": {
        "jsCode": "const webhookData = $input.first().json.body || $input.first().json;\n\nconst callData = {\n  call_id: webhookData.data?.id || webhookData.call_id,\n  external_id: `aircall_${webhookData.data?.id}`,\n  started_at: webhookData.data?.started_at,\n  ended_at: webhookData.data?.answered_at ? \n    new Date(webhookData.data.answered_at * 1000 + (webhookData.data.duration * 1000)).toISOString() :\n    new Date().toISOString(),\n  duration_seconds: webhookData.data?.duration || 0,\n  caller_number: webhookData.data?.raw_digits || webhookData.data?.number?.digits,\n  caller_name: webhookData.data?.contact?.first_name ? \n    `${webhookData.data.contact.first_name} ${webhookData.data.contact.last_name || ''}`.trim() :\n    'Unknown Caller',\n  agent_id: webhookData.data?.user?.id,\n  agent_name: webhookData.data?.user?.name,\n  agent_email: webhookData.data?.user?.email,\n  direction: webhookData.data?.direction || 'inbound',\n  call_type: webhookData.data?.call_type || 'voice',\n  status: webhookData.data?.status || 'done',\n  recording_url: webhookData.data?.recording,\n  has_recording: !!webhookData.data?.recording,\n  hubspot_contact_id: webhookData.data?.contact?.hubspot_id || null,\n  processed_at: new Date().toISOString(),\n  workflow_version: '1.0.0',\n  source: 'aircall'\n};\n\nreturn [{ json: callData }];\n"
      },
      "id": "2429dd21-5b4e-4d7e-be09-7a8f5f1d1176",
      "name": "Extract Call Metadata",
