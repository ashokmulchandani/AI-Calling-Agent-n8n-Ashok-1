            "version": 1
          },
          "conditions": [
            {
              "leftValue": "={{ $json.body.event }}",
              "rightValue": "call.ended",
              "operator": {
                "type": "string",
                "operation": "equals"
              },
              "id": "c79b8bc5-131d-438e-b136-393f373c5ccf"
